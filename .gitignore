# Local .terraform directories
**/.terraform/

# Terraform lock file (generated per consumer, not part of the module)
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files
*.tfplan
tfplan

# Crash log
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example*.tfvars

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated zip archives (e.g. from archive_file data source)
*.zip

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo

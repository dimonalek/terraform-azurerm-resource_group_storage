# Local .terraform directories
**/.terraform/

# Terraform lock file (generated locally)
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files
*.tfplan
tfplan

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated archives
*.zip

# Editor/OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo
